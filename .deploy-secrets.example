# Network Solutions FTP credentials — COPY this file to ".deploy-secrets" and fill in.
# The real ".deploy-secrets" is git-ignored, so it is NEVER committed or pushed.
# Do NOT paste these values into chat — just edit the file locally.

# The FTP server address from your Network Solutions hosting panel.
# Often looks like "ftp.elephanthawk.com" or a server hostname they give you.
FTP_HOST="ftp.elephanthawk.com"

# Your FTP username (from the hosting panel's FTP section).
FTP_USER="your-ftp-username"

# Your FTP password.
FTP_PASS="your-ftp-password"

# The folder on the server that is your website's public root.
# We'll confirm this by listing the server first. Common values:
#   /        or   /htdocs        or   /www        or   /public_html
# Leave as "/" for now; we'll correct it after listing.
FTP_DIR="/"
