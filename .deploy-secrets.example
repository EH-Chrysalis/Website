# Network Solutions SFTP credentials — COPY this file to ".deploy-secrets" and fill in.
# The real ".deploy-secrets" is git-ignored, so it is NEVER committed or pushed.
# Do NOT paste these values into chat — just edit the file locally.
#
# Deploys use SFTP (encrypted) on port 22, with the same username/password
# Network Solutions gives you for FTP.

# The server address from your Network Solutions hosting panel
# (e.g. ftp-XXXXXXXX.registeredsite.com). No "ftp://" prefix.
FTP_HOST="ftp-XXXXXXXX.registeredsite.com"

# Your hosting username.
FTP_USER="your-username"

# Your password.
FTP_PASS="your-password"

# The website's public root on the server. For Network Solutions this is /htdocs.
FTP_DIR="/htdocs"

# SFTP port (Network Solutions uses the standard 22).
SFTP_PORT="22"
